      "source": [
        "Loading Dataset"
      ],
      "metadata": {
        "id": "0X8J5qPIiiM6"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "from sklearn.datasets import fetch_openml\n",
        "\n",
        "data = fetch_openml(name='adult', version=2, as_frame=True)\n",
        "\n",
        "df = data.frame\n",
        "\n",
        "print(df.head())"
      ],
      "metadata": {
